---
type Props = {
	description: string;
	href: string;
	icon: string;
	title: string;
};

const { description, href, icon, title } = Astro.props;
---

<article class="project-card">
	<div class="project-card-heading">
		<span aria-hidden="true" class="project-card-icon">{icon}</span>
		<h3 class="project-card-title">
			<a class="typefolio-link-lighter" href={href} rel="noreferrer noopener" target="_blank">
				{title}
			</a>
		</h3>
	</div>
	<p class="project-card-description">{description}</p>
</article>
