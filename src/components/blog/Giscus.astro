---
import { giscusConfig } from "@/site.config";

const config = {
	category: giscusConfig.category,
	categoryId: giscusConfig.categoryId,
	repo: giscusConfig.repo,
	repoId: giscusConfig.repoId,
};
---

<section aria-label="Comments" class="not-prose mt-12">
	<h2 class="title mb-4 text-lg before:hidden">Comments</h2>
	<div class="giscus"></div>
</section>

<script
	is:inline
	define:vars={{
		category: config.category,
		categoryId: config.categoryId,
		repo: config.repo,
		repoId: config.repoId,
	}}
>
	const GISCUS_HOST = "https://giscus.app";
	const root = document.documentElement;

	function getGiscusTheme() {
		return root.getAttribute("data-theme") === "dark" ? "dark" : "light";
	}

	function syncGiscusTheme() {
		const iframe = document.querySelector<HTMLIFrameElement>("iframe.giscus-frame");
		if (!iframe?.contentWindow) return;

		iframe.contentWindow.postMessage(
			{ giscus: { setConfig: { theme: getGiscusTheme() } } },
			GISCUS_HOST,
		);
	}

	function mountGiscus() {
		const container = document.querySelector<HTMLElement>(".giscus");
		if (!container) return;
		if (container.querySelector("script[data-giscus-script='true']")) return;

		const script = document.createElement("script");
		script.src = `${GISCUS_HOST}/client.js`;
		script.async = true;
		script.crossOrigin = "anonymous";
		script.setAttribute("data-giscus-script", "true");
		script.setAttribute("data-repo", repo);
		script.setAttribute("data-repo-id", repoId);
		script.setAttribute("data-category", category);
		script.setAttribute("data-category-id", categoryId);
		script.setAttribute("data-theme", getGiscusTheme());
		container.appendChild(script);
	}

	mountGiscus();
	syncGiscusTheme();

	document.addEventListener("theme-change", syncGiscusTheme);
	document.addEventListener("astro:after-swap", () => {
		mountGiscus();
		syncGiscusTheme();
	});

	// Keep giscus in sync when the theme changes via OS preference media query.
	const themeObserver = new MutationObserver(() => syncGiscusTheme());
	themeObserver.observe(root, { attributeFilter: ["data-theme"], attributes: true });
</script>
