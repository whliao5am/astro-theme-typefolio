---
import { type CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import PostPreview from "@/components/blog/PostPreview.astro";
import type { WhatsNewItem } from "@/components/home/WhatsNewTimeline.astro";
import WhatsNewTimeline from "@/components/home/WhatsNewTimeline.astro";
import InlineIconLink from "@/components/InlineIconLink.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"blog">[];

// Pinned Posts, set to a max of 3;
const MAX_PINNED_POSTS = 5;
const pinnedPosts = allPostsByDate.filter((p) => p.data.pinned).slice(0, MAX_PINNED_POSTS);

const whatsNewItems: WhatsNewItem[] = [
	{
		date: "Mar 2026",
		kind: "milestone",
		label: "Milestone",
		description:
			"Released a redesigned archive view prototype with improved reading rhythm and lighter metadata treatment across the homepage.",
	},
	{
		date: "Feb 2026",
		kind: "service",
		label: "Service",
		description:
			"Joined the fictional Aurora Systems Workshop program committee to review submissions on dependable software tooling and interface design.",
	},
	{
		date: "Jan 2026",
		kind: "paper",
		label: "Paper",
		description:
			"Shared a sample preprint on modular note-taking workflows for small research groups, using a fully synthetic project and placeholder dataset.",
		href: "/blog/markdown-elements/",
	},
	{
		date: "Dec 2025",
		kind: "talk",
		label: "Talk",
		description:
			"Gave an internal demo on how a clean timeline can present research progress, product updates, and writing milestones on a single homepage.",
	},
	{
		date: "Nov 2025",
		kind: "award",
		label: "Award",
		description:
			"Received the imaginary North Pier Design Mention for a prototype blog that balanced editorial typography with practical documentation needs.",
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<div class="index-content">
		<section>
			<h1 class="title mb-4">Astro Typefolio</h1>
			<p>
				Typefolio is a professional, elegant, static-fast Astro template for researchers and developers
				who want a focused place for writing, projects, notes, and release updates.
				It keeps the entry surface concise so visitors understand the template quickly without
				wading through a starter-kit checklist.
			</p>
			<p>
				Use the
				<InlineIconLink
					href="https://github.com/whliao5am/astro-theme-typefolio"
					icon="mdi:github"
					label="GitHub repository"
					width="1.5em"
					height="1.5em"
					target="_blank"
				/>
				to clone the template, inspect the current feature set, and track the official v1 content
				refresh.
			</p>
			<p>
				From here, the homepage points to the essentials first: pinned writing, current news, and
				the repository entry point that powers the full Typefolio setup.
			</p>
		</section>
	</div>

	{
		pinnedPosts.length > 0 && (
			<section class="mt-8">
				<h2 class="title mb-4 flex items-center gap-2 text-xl">
					Pinned Posts
          <Icon
								aria-hidden="true"
								class="h-5 w-5 rotate-45 text-accent"
								focusable="false"
								name="mdi:pin-outline"
							/>
				</h2>
				<ul class="space-y-1" role="list">
					{pinnedPosts.map((p) => (
						<li class="grid sm:grid-cols-[auto_1fr]">
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}

	<WhatsNewTimeline items={whatsNewItems} />
</PageLayout>
