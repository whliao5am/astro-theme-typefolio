---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description:
		"Astro Typefolio is a concise publishing template for researchers and developers.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">About</h1>
	<div class="index-content">
		<p>
			Astro Typefolio is built for researchers and developers who want a
			professional personal site without a heavy product shell. The goal is
			simple: publish writing, project pages, tags, and news updates with a
			presentation that stays elegant, static-fast, and easy to maintain.
		</p>
		<p>
			The template follows Occam&apos;s razor by keeping only the publishing
			surfaces that help readers understand your work quickly.
		</p>
		<p>Typefolio ships with the following built-in capabilities:</p>
		<ul class="list-inside list-disc" role="list">
			<li>Posts and tag archives with Astro content collections</li>
			<li>Typography-first layouts with light and dark themes</li>
			<li>Pinned posts and a concise What&apos;s New timeline</li>
			<li>Backlinks and richer Markdown publishing features</li>
			<li>Pagefind search and optional Giscus comments</li>
			<li>Generated OG images and local bilingual fonts</li>
		</ul>
		<p>
			Clone or fork the <a
				class="typefolio-link inline-block"
				href="https://github.com/whliao5am/astro-theme-typefolio"
				rel="noreferrer"
				target="_blank">https://github.com/whliao5am/astro-theme-typefolio</a
			>
		</p>
	</div>
</PageLayout>
