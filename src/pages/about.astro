---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Astro Typefolio is a concise publishing template for researchers and developers.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">About Astro Typefolio</h1>
	<div class="index-content">
		<p>
			Astro Typefolio is built for researchers and developers who want a professional personal site
			without a heavy product shell. The goal is simple: publish writing, notes, project pages, tags,
			and news updates with a presentation that stays elegant, static-fast, and easy to maintain.
		</p>
		<p>
			The template follows Occam&apos;s razor by keeping only the publishing surfaces that help readers
			understand your work quickly. The homepage stays concise; this page explains the template&apos;s
			positioning and repository starting point in more detail.
		</p>
		<p>
			Clone or fork the <a
				class="typefolio-link inline-block"
				href="https://github.com/whliao5am/astro-theme-typefolio"
				rel="noreferrer"
				target="_blank">https://github.com/whliao5am/astro-theme-typefolio</a
			> to start from the current template baseline, then tailor the content model, visual tone, and
			navigation to your own work.
		</p>
	</div>
</PageLayout>
